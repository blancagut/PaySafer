# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
# Obtén estas credenciales desde: https://app.supabase.com/project/_/settings/api

# URL pública de tu proyecto Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co

# Clave anónima pública (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Clave de rol de servicio (NUNCA expongas en el cliente)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key


# ============================================================================
# STRIPE CONFIGURATION
# ============================================================================
# Get these credentials from: https://dashboard.stripe.com/apikeys
# NOTE: Use TEST keys (sk_test_*, pk_test_*) for development
#       Use LIVE keys (sk_live_*, pk_live_*) for production

# Server-side secret key - NEVER expose to client
# Used in: lib/stripe/server.ts
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Client-side publishable key (safe to expose in browser)
# Used in: Client-side Stripe.js initialization
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Webhook signature verification secret
# Get from: https://dashboard.stripe.com/webhooks
# Used in: app/api/webhooks/stripe/route.ts
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# Webhook timestamp tolerance (seconds)
# Allowed range: 60-600 seconds
# Default: 300 seconds (5 minutes)
WEBHOOK_TIMESTAMP_TOLERANCE=300


# ============================================================================
# PUSH NOTIFICATIONS (Web Push / VAPID)
# ============================================================================
# Generate VAPID keys with: npx web-push generate-vapid-keys
# Public key is safe for the client
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key

# Private key is server-only — NEVER expose to client
VAPID_PRIVATE_KEY=your-vapid-private-key

# Contact email for the push service
VAPID_EMAIL=mailto:you@example.com


# ============================================================================
# EMAIL NOTIFICATIONS (Resend)
# ============================================================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# "From" address for transactional emails (must be a verified domain)
RESEND_FROM_EMAIL=notifications@yourdomain.com


# ============================================================================
# APP CONFIGURATION
# ============================================================================
# Public URL of your deployed app (used in emails, Stripe redirects, etc.)
NEXT_PUBLIC_APP_URL=https://www.paysafer.site

# OpenAI API key (for AI copilot, translations, offer optimizer, support)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key

# ============================================================================
# RAPIDAPI (YFINANCE API)
# ============================================================================
# RapidAPI key for yahoo-finance166 endpoint
RAPIDAPI_KEY=your-rapidapi-key

# Backward-compatible host (optional)
RAPIDAPI_HOST=yahoo-finance166.p.rapidapi.com

# Dedicated host for Yahoo Finance news endpoint
RAPIDAPI_YFINANCE_HOST=yahoo-finance166.p.rapidapi.com

# Dedicated host for Alpha Vantage stocks endpoint
RAPIDAPI_ALPHA_VANTAGE_HOST=alpha-vantage.p.rapidapi.com

# ============================================================================
# RATE-API.COM (FX rates & conversion)
# ============================================================================
# Free tier: 1,000 requests/month. Used for live FX conversion.
# Get your key at https://rate-api.com
RATE_API_KEY=your-rate-api-key

# ============================================================================
# CURRENTS API (Market News)
# ============================================================================
# Primary news provider — finance, stocks, crypto, forex, economy, politics.
# Free tier: 600 requests/day. Docs: https://currentsapi.services/en/docs/
CURRENTS_API_KEY=your-currents-api-key

# Super admin email — this account has elevated AML privileges
# and can NEVER be banned or demoted
SUPER_ADMIN_EMAIL=renzocarlosme@gmail.com

# Treasury wallet user ID (PAYSAFERME LLC account in Supabase auth.users)
# Required for Anti ML confiscation — funds are moved to this wallet
# Create the treasury user first, then copy its UUID here
PAYSAFER_TREASURY_USER_ID=uuid-of-treasury-user


# ============================================================================
# GOOGLE PLACES (RapidAPI) — ATM Finder
# ============================================================================
# RapidAPI host for Google Places (new v2)
GOOGLE_PLACES_RAPIDAPI_HOST=google-map-places-new-v2.p.rapidapi.com

# ATM search cache duration in minutes (default: 60)
ATM_SEARCH_CACHE_MINUTES=60


# ============================================================================
# BINANCE CONFIGURATION (Crypto Trading)
# ============================================================================
# Get your API keys from: https://www.binance.com/en/my/settings/api-management
# Required permissions: Enable Reading + Enable Spot & Margin Trading
# IMPORTANT: Restrict API key to trusted IPs only

# Binance API key
BINANCE_API_KEY=your-binance-api-key

# Binance API secret — NEVER expose to client
BINANCE_API_SECRET=your-binance-api-secret

# Use Binance testnet for development (true/false)
# Testnet: https://testnet.binance.vision
# Set to "false" for production with real funds
USE_BINANCE_TESTNET=true
